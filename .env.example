# ───────────────────────────────────────────────────────────────────────────
# Bonsai Companion — environment variables template
# Copy to `.env.local` (git-ignored) and fill in. NEVER commit real values.
# Full reference & where each value comes from: docs/setup/04-environment-variables.md
# ───────────────────────────────────────────────────────────────────────────

# --- Supabase (public — safe to ship to the browser) ---
# Supabase → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
# Supabase → Settings → API Keys → Publishable key (starts with sb_publishable_).
# This is the 2026 client key (replaces the old "anon" key). It carries the same
# low privileges, so Row-Level Security still constrains everything it can do.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_YOUR-KEY"

# --- App ---
# Used for auth redirects & absolute URLs. Local: http://localhost:3000
# Production: your deployed URL (e.g. https://bonsai-companion.vercel.app)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Server-only secret (OPTIONAL — only if a server route must bypass RLS) ---
# Supabase → Settings → API Keys → Secret keys (starts with sb_secret_).
# NEVER prefix with NEXT_PUBLIC_ — it must never reach the browser. Bypasses RLS.
# The MVP aims to avoid needing this at all.
# SUPABASE_SECRET_KEY="sb_secret_YOUR-KEY"

# --- Owner-only admin page (server-only; set in Vercel for production) ---
# Supabase → Authentication → Users → your row's UID. Gates /admin (owner
# metrics) + the Settings link to it; everyone else gets a 404.
# OWNER_USER_ID="YOUR-AUTH-USER-UUID"

# ───────────────────────────────────────────────────────────────────────────
# Used by the Supabase CLI / CI, not the running app. Keep in your shell env or
# CI secrets, not necessarily in .env.local.
# ───────────────────────────────────────────────────────────────────────────
# Supabase → Settings → General → Reference ID (the <ref> in your project URL)
# SUPABASE_PROJECT_REF="YOUR-PROJECT-REF"
# Created by `supabase login` (CLI auth) — local/CI only, SECRET
# SUPABASE_ACCESS_TOKEN="YOUR-CLI-ACCESS-TOKEN"
