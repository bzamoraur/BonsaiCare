# ───────────────────────────────────────────────────────────────────────────
# Bonsai Companion — environment variables template
# Copy to `.env.local` (git-ignored) and fill in. NEVER commit real values.
# Full reference & where each value comes from: docs/setup/04-environment-variables.md
# ───────────────────────────────────────────────────────────────────────────

# --- Supabase (public — safe in the browser; RLS constrains the anon key) ---
# Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
# Supabase → Project Settings → API → anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-PUBLIC-KEY"

# --- App ---
# Used for auth redirects & absolute URLs. Local: http://localhost:3000
# Production: your deployed URL (e.g. https://bonsai-companion.vercel.app)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Server-only secret (OPTIONAL — only if a server route truly needs to
#     bypass RLS). Keep OUT of the client bundle and OUT of git. The MVP aims
#     to avoid needing this. Supabase → Project Settings → API → service_role ---
# SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-SECRET"

# ───────────────────────────────────────────────────────────────────────────
# The following are used by the Supabase CLI / CI, not the running app.
# Keep them in your shell env or CI secrets, not necessarily in .env.local.
# ───────────────────────────────────────────────────────────────────────────
# Supabase → Project Settings → General → Reference ID
# SUPABASE_PROJECT_REF="YOUR-PROJECT-REF"
# Created by `supabase login` (CLI auth) — local/CI only, SECRET
# SUPABASE_ACCESS_TOKEN="YOUR-CLI-ACCESS-TOKEN"
